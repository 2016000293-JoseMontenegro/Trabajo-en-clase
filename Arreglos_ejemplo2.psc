Algoritmo Ejemplo2
	//Problema solicitar 6 notas de un estudiante x de IVC del cuso de programación
	Definir notas, i Como Entero
	dimension notas[6]
	
	Para i=1 Hasta 6 Con Paso 1 Hacer
		Escribir Sin Saltar "Dime la nota ",i, ": "
		leer notas[i]
	Fin Para
	
	//Mostrar los valores del arreglo
	Para i = 1 Hasta 6 Con Paso 1 Hacer
		Escribir Sin Saltar notas[i], " - "
	Fin Para
FinAlgoritmo
